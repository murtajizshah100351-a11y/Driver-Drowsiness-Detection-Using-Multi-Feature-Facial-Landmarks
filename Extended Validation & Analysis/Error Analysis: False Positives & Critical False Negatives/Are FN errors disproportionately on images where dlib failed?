# A7.3 — Are FN errors disproportionately on images where dlib failed?
fail_rate_fn = critical['face_det'].mean() if len(critical) else float('nan')
fail_rate_correct = errors[errors['error_type']=='correct']['face_det'].mean()
print('═'*65)
print('IS dlib FAILURE A PREDICTOR OF CRITICAL ERRORS?')
print('═'*65)
print(f'Face-detection rate among CORRECT predictions: {100*fail_rate_correct:.1f}%')
print(f'Face-detection rate among critical FNs:        {100*fail_rate_fn:.1f}%')
if not np.isnan(fail_rate_fn) and fail_rate_fn < fail_rate_correct - 0.05:
    print('\n⚠️  When dlib fails, the model loses its handcrafted EAR/MAR signal and'
          ' relies on the CNN alone, which over-predicts "alert".')
    print('     Mitigation: weight the CNN-only branch differently when dlib fails,'
          ' or fall back to a temporal model.')

