# A3.2 — Paired bootstrap test: ensemble vs each baseline
def paired_bootstrap_test(y_true, p_a, p_b, metric_fn, n_boot=1000, seed=SEED):
    """Test whether p_a is significantly different from p_b (paired on test items)."""
    rng = np.random.RandomState(seed)
    n = len(y_true)
    diffs = []
    for _ in range(n_boot):
        idx = rng.randint(0, n, n)
        y_t = y_true[idx]
        if len(np.unique(y_t)) < 2:
            continue
        try:
            diffs.append(metric_fn(y_t, p_a[idx]) - metric_fn(y_t, p_b[idx]))
        except ValueError:
            continue
    diffs = np.array(diffs)
    # Two-sided p-value: probability that the observed mean is on the wrong side of 0
    p_two = 2 * min((diffs <= 0).mean(), (diffs >= 0).mean())
    return diffs.mean(), np.percentile(diffs, 2.5), np.percentile(diffs, 97.5), p_two

