# A3.3 — McNemar's test (paired classifier comparison)
from scipy.stats import binomtest

def mcnemar(y_true, pred_a, pred_b):
    """Exact McNemar — recommended over chi-square when discordant pairs are few."""
    a_correct = (pred_a == y_true)
    b_correct = (pred_b == y_true)
    n01 = ((~a_correct) & ( b_correct)).sum()  # A wrong, B right
    n10 = (( a_correct) & (~b_correct)).sum()  # A right, B wrong
    if n01 + n10 == 0:
        return 1.0, n01, n10
    p = binomtest(min(n01, n10), n01 + n10, 0.5).pvalue
    return p, n01, n10

