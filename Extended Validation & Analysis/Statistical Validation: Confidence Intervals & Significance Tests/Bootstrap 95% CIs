# A3.1 — Bootstrap 95% CIs for accuracy / F1 / AUC of every model
from sklearn.utils import resample

def bootstrap_ci(y_true, y_prob, metric_fn, n_boot=1000, alpha=0.05, seed=SEED):
    rng = np.random.RandomState(seed)
    n = len(y_true)
    vals = []
    for _ in range(n_boot):
        idx = rng.randint(0, n, n)
        y_t = y_true[idx]
        y_p = y_prob[idx]
        # Skip degenerate resamples
        if len(np.unique(y_t)) < 2:
            continue
        try:
            vals.append(metric_fn(y_t, y_p))
        except ValueError:
            continue
    vals = np.array(vals)
    return vals.mean(), np.percentile(vals, 100*alpha/2), np.percentile(vals, 100*(1 - alpha/2))

def acc_metric(y, p): return accuracy_score(y, (p >= 0.5).astype(int))
def f1_metric(y, p):  return f1_score(y, (p >= 0.5).astype(int), zero_division=0)
def auc_metric(y, p): return roc_auc_score(y, p)

