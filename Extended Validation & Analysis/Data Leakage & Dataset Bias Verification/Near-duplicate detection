# A1.2 — Perceptual-hash near-duplicate detection
# Catches the case where two near-identical frames (e.g., consecutive video frames)
# end up split between train and test.
import hashlib

def phash_8x8(path):
    """Tiny 64-bit average-hash. Fast and good enough to flag near-duplicates."""
    img = cv2.imread(path, cv2.IMREAD_GRAYSCALE)
    if img is None:
        return None
    img = cv2.resize(img, (8, 8), interpolation=cv2.INTER_AREA)
    avg = img.mean()
    bits = (img > avg).flatten()
    return int(''.join('1' if b else '0' for b in bits), 2)

